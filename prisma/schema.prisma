datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  discordId String   @unique
  username  String
  createdAt DateTime @default(now())
}

model GuildLog {
  id        String   @id @default(uuid())
  guildId   String
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
}
